{
	"name": "coding-library",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@tiptap/core": "^3.22.4",
		"@tiptap/extension-code-block-lowlight": "^3.22.4",
		"@tiptap/extension-link": "^3.22.4",
		"@tiptap/extension-placeholder": "^3.22.4",
		"@tiptap/extension-task-item": "^3.22.4",
		"@tiptap/extension-task-list": "^3.22.4",
		"@tiptap/pm": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4",
		"hast-util-to-html": "^9.0.5",
		"lowlight": "^3.3.0"
	}
}
